# Supabase Edge Functions Environment Variables
#
# Copy this file to .env and fill in the values for local development.
# For production, set these in your Supabase project settings.

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# OPTIONAL: Redis Caching (Upstash)
# =============================================================================
#
# Redis caching is OPTIONAL. When not configured, the app uses in-memory caching.
# This is suitable for development and small deployments.
#
# For production with high traffic, we recommend Upstash Redis:
# 1. Create a free account at https://upstash.com
# 2. Create a Redis database
# 3. Copy the REST URL and token from your Upstash dashboard
#
# Benefits of Redis:
# - Persistent cache across Edge Function restarts
# - Shared cache across multiple function instances
# - Consistent rate limiting across distributed deployments

# Upstash Redis REST URL (leave empty to use in-memory cache)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Example Upstash Configuration
# =============================================================================
# UPSTASH_REDIS_REST_URL=https://us1-example-12345.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL: Email Notifications (Resend)
# =============================================================================
# Required for the send-invitation and notify-new-signup edge functions.

# Resend API key (https://resend.com)
# RESEND_API_KEY=re_your_api_key

# Base URL for links in emails (e.g., invitation accept links)
# APP_URL=https://your-domain.com

# Sender email address
# EMAIL_FROM=Eryxon <noreply@your-domain.com>

# Email address to receive admin signup notifications (notify-new-signup function)
# SIGNUP_NOTIFY_EMAIL=admin@your-domain.com

# =============================================================================
# REQUIRED (production): CORS
# =============================================================================
# The frontend origin allowed to call edge functions.
# If not set, only localhost origins are permitted (safe for local dev).
# For production, set this to your frontend domain.
ALLOWED_ORIGIN=https://your-domain.com

# =============================================================================
# OPTIONAL: Cron & Self-Hosting
# =============================================================================

# Secret for authenticating cron job invocations
# CRON_SECRET=your-cron-secret

# Set to "true" for self-hosted deployments (changes UI messaging in plan-mode; does not disable plan limits)
# SELF_HOSTED_MODE=true
