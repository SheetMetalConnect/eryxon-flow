---
import config from "@/config/config.json";
import social from "@/config/social.json";
import { Icon } from "@astrojs/starlight/components";
import { markdownify } from "@/lib/utils/textConverter";
import { getTranslations } from "@/lib/utils/languagePerser";
import { localizePath, type Locale } from "@/lib/locale";

const locale = Astro.currentLocale;

const menu = await getTranslations(locale || "en");

const footer = menu.footer;
const currentLocal = Astro.currentLocale || "en";

// Localized legal labels, matching the marketing SiteFooter.
const legalLabels: Record<Locale, { imprint: string; privacy: string }> = {
  en: { imprint: "Imprint", privacy: "Privacy" },
  nl: { imprint: "Impressum", privacy: "Privacy" },
  de: { imprint: "Impressum", privacy: "Datenschutz" },
};

// Opt-in CTA tracking attributes for Phase 1 footer links (ERY-33).
// Only links that declare `ctaId` in the menu config emit tracking attributes.
const ctaAttrs = (link: any) =>
  link?.ctaId
    ? {
        "data-cta-id": link.ctaId,
        "data-cta-surface": link.ctaSurface ?? "footer",
        "data-cta-kind": link.ctaKind,
        "data-cta-target": link.url,
      }
    : {};

const ctaHref = (link: any) =>
  link && typeof link.url === "string" ? link.url : "#";
---

{/* Single docs footer, rendered on every Starlight surface (docs pages
    included). IA mirrors the marketing SiteFooter: a brand column, then
    Repository / Resources / Contact. Language switching lives in the header,
    so the old footer language column is gone. Calm, light-first, --ery-* only. */}
<footer>
  <div class="container">
    <div class="top-footer">
      <div class="footer-brand">
        <h4 class="brand-title">Eryxon Flow</h4>
        <p class="brand-note">
          Manufacturing execution for metalworking job shops. Free and open source under
          <a href="https://github.com/SheetMetalConnect/eryxon-flow/blob/main/LICENSE" target="_blank" rel="noopener">Apache 2.0</a>.
        </p>
        <ul class="social-icons">
          {social.main.map((item) => (
            <li>
              <a href={item.href} aria-label={item.label} target="_blank" rel="noopener">
                <Icon name={item?.icon as any} color="currentColor" size="20px" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      {
        footer.community && (
          <nav aria-label={footer.community.title}>
            <h4>{footer.community.title}</h4>
            <ul>
              {footer.community?.links.map((link: any) => (
                <li>
                  <a href={ctaHref(link)} {...ctaAttrs(link)}>{link.name}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
      {
        footer.help_links && (
          <nav aria-label={footer.help_links.title}>
            <h4>{footer.help_links.title}</h4>
            <ul>
              {footer.help_links?.links.map((link: any) => (
                <li>
                  <a href={ctaHref(link)} {...ctaAttrs(link)}>{link.name}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
      {
        footer.company && (
          <nav aria-label={footer.company.title}>
            <h4>{footer.company.title}</h4>
            <ul>
              {footer.company?.links.map((link: any) => (
                <li>
                  <a href={ctaHref(link)} {...ctaAttrs(link)}>{link.name}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>
    <div class="bottom-footer">
      <p set:html={markdownify(config?.params?.copyright)} />
      <nav class="legal-links" aria-label="Legal">
        <a href={localizePath("/imprint/", currentLocal as Locale)}>{legalLabels[currentLocal as Locale]?.imprint ?? "Imprint"}</a>
        <a href={localizePath("/privacy/", currentLocal as Locale)}>{legalLabels[currentLocal as Locale]?.privacy ?? "Privacy"}</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  @layer starlight.core {
    /* Docs footer — mirrors the marketing SiteFooter contract. Brand column is
       wider; nav columns are equal. Borders carry separation, --ery-* only. */
    .top-footer {
      border-block-start: 1px solid var(--ery-border);
      padding: var(--ery-space-16) 0 var(--ery-space-12);
      display: grid;
      gap: var(--ery-space-8);
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
    @media (max-width: 860px) {
      .top-footer {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 480px) {
      .top-footer {
        grid-template-columns: 1fr;
      }
    }

    .top-footer h4 {
      font-family: var(--ery-font-mono);
      font-size: var(--ery-text-xs) !important;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ery-text-subtle);
      margin: 0 0 var(--ery-space-4);
      font-weight: 500;
    }
    .top-footer ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--ery-space-2);
    }
    .top-footer ul li {
      margin: 0;
    }
    .top-footer a {
      color: var(--ery-text-muted);
      text-decoration: none;
      font-size: var(--ery-text-sm);
      transition: color var(--ery-motion-base) var(--ery-ease);
    }
    .top-footer a:hover {
      color: var(--ery-brand);
    }

    .footer-brand .brand-title {
      font-family: var(--ery-font-sans);
      font-size: var(--ery-text-base) !important;
      text-transform: none;
      letter-spacing: var(--ery-tracking-tight);
      color: var(--ery-text);
      font-weight: 600;
      margin: 0 0 var(--ery-space-3);
    }
    .footer-brand .brand-note {
      margin: 0;
      max-inline-size: 36ch;
      font-size: var(--ery-text-sm);
      line-height: var(--ery-leading-relaxed);
      color: var(--ery-text-muted);
    }
    .footer-brand .brand-note a {
      color: var(--ery-brand);
    }

    .social-icons {
      display: flex;
      gap: var(--ery-space-3);
      margin-block-start: var(--ery-space-5);
      flex-wrap: wrap;
      list-style: none;
      padding: 0;
    }
    .social-icons li a {
      color: var(--ery-text-muted);
      width: 40px;
      height: 40px;
      border: 1px solid var(--ery-border);
      border-radius: var(--ery-radius-pill);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color var(--ery-motion-base) var(--ery-ease),
        border-color var(--ery-motion-base) var(--ery-ease);
    }
    .social-icons li a:hover {
      color: var(--ery-brand);
      border-color: var(--ery-border-strong);
    }

    .bottom-footer {
      padding: var(--ery-space-6) 0;
      border-block-start: 1px solid var(--ery-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--ery-space-3) var(--ery-space-6);
      font-size: var(--ery-text-xs);
      color: var(--ery-text-subtle);
    }
    .bottom-footer :global(p) {
      margin: 0;
    }
    .legal-links {
      display: flex;
      gap: var(--ery-space-5);
    }
    .bottom-footer a {
      color: var(--ery-text-subtle);
      text-decoration: none;
      transition: color var(--ery-motion-base) var(--ery-ease);
    }
    .bottom-footer a:hover {
      color: var(--ery-brand);
    }
  }
</style>
