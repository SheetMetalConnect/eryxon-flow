---
const { title, description } = Astro.props;
---

<section class="section">
  <div class="section-divider"></div>
  <div class="text-center mb-16">
    {title && <h2 class="section-title mb-4" set:html={(title)} />}
    {description && <p class="section-description max-w-2xl mx-auto" set:html={description} />}
  </div>

  <div>
    <slot />
  </div>
</section>

<style>
  .section-divider {
    width: 48px;
    height: 2px;
    background: var(--color-primary-gradient);
    margin: 0 auto 3rem;
    border-radius: 1px;
    opacity: 0.6;
  }
</style>
