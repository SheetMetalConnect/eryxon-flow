---
/*
 * Roadmap.astro — product roadmap surface (`/roadmap/`, EN + `/nl/`, `/de/`).
 *
 * Our own content first: three status columns (Shipped / In progress / Planned) rendered in the
 * marketing design system, with real items. Native iOS/Android sit under "In progress" — work in
 * flight, not yet shipped. The public Canny board (https://eryxon.canny.io/) is paired in as a
 * "vote on it" CTA rather than a bare iframe, so the page stays useful even where framing is
 * blocked. No version numbers here (those live in the release notes).
 *
 * Copy is locale-driven (`marketing-content.ts`). Styling uses the shared `--ery-*` token contract
 * only — status accents map to the semantic state tokens (success / warning / subtle).
 */
import { roadmapCopy, CANNY_ROADMAP_URL, type RoadmapStatus } from "@/lib/marketing-content";
import type { Locale } from "@/lib/locale";

interface Props {
  locale?: Locale;
}
const { locale = "en" } = Astro.props;
const c = roadmapCopy(locale);

// Group items by status so each column renders its own list.
const itemsByStatus = (status: RoadmapStatus) => c.items.filter((it) => it.status === status);
---

<section class="ery-container rm-hero">
  <p class="rm-eyebrow">{c.hero.eyebrow}</p>
  <h1 class="rm-h1">{c.hero.h1}</h1>
  <p class="rm-lede">{c.hero.lead}</p>
</section>

<section class="ery-container rm-board" aria-label={c.hero.h1}>
  <div class="rm-cols">
    {c.columns.map((col) => (
      <div class:list={["rm-col", `is-${col.status}`]}>
        <div class="rm-col-head">
          <span class="rm-dot"></span>
          <h2 class="rm-col-label">{col.label}</h2>
          <span class="rm-col-count">{itemsByStatus(col.status).length}</span>
        </div>
        <ul class="rm-list">
          {itemsByStatus(col.status).map((it) => (
            <li class="rm-item">
              <h3 class="rm-item-title">{it.title}</h3>
              <p class="rm-item-note">{it.note}</p>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<section class="ery-container rm-vote-wrap">
  <div class="rm-vote">
    <div class="rm-vote-text">
      <p class="rm-vote-eyebrow">{c.vote.eyebrow}</p>
      <h2 class="rm-vote-h">{c.vote.h}</h2>
      <p class="rm-vote-b">{c.vote.b}</p>
    </div>
    <a
      class="rm-vote-cta"
      href={CANNY_ROADMAP_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-cta-id="roadmap_vote_canny"
      data-cta-surface="roadmap"
      data-cta-kind="external"
    >
      {c.vote.cta}
    </a>
  </div>
</section>

<style>
  /* ---------- Hero ---------- */
  .rm-hero {
    text-align: center;
    max-inline-size: 52rem;
    padding-block: var(--ery-pad-hero) var(--ery-space-12);
  }
  .rm-eyebrow {
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ery-brand);
    margin: 0 0 var(--ery-space-3);
  }
  .rm-h1 {
    font-size: clamp(var(--ery-text-3xl), 4.5vw, var(--ery-text-5xl));
    line-height: var(--ery-leading-tight);
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin: 0 0 var(--ery-space-4);
  }
  .rm-lede {
    font-size: var(--ery-text-lg);
    line-height: var(--ery-leading-relaxed);
    color: var(--ery-text-muted);
    max-inline-size: 40rem;
    margin-inline: auto;
  }

  /* ---------- Status columns ---------- */
  .rm-board {
    padding-block-end: var(--ery-space-16);
  }
  .rm-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--ery-space-5);
    align-items: start;
  }
  .rm-col {
    background: var(--ery-surface-subtle);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-lg);
    padding: var(--ery-space-5);
  }
  .rm-col-head {
    display: flex;
    align-items: center;
    gap: var(--ery-space-3);
    padding-block-end: var(--ery-space-4);
    margin-block-end: var(--ery-space-4);
    border-block-end: 1px solid var(--ery-border);
  }
  .rm-dot {
    inline-size: 9px;
    block-size: 9px;
    border-radius: var(--ery-radius-pill);
    flex-shrink: 0;
  }
  .is-shipped .rm-dot { background: var(--ery-success); }
  .is-progress .rm-dot { background: var(--ery-warning); }
  .is-planned .rm-dot { background: var(--ery-text-subtle); }
  .rm-col-label {
    margin: 0;
    font-size: var(--ery-text-sm);
    font-weight: 600;
    color: var(--ery-text);
  }
  .rm-col-count {
    margin-inline-start: auto;
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    color: var(--ery-text-subtle);
  }

  .rm-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ery-space-3);
  }
  .rm-item {
    background: var(--ery-surface);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-sm);
    padding: var(--ery-space-4);
    transition: border-color var(--ery-motion-base) var(--ery-ease);
  }
  .rm-item:hover {
    border-color: var(--ery-border-strong);
  }
  /* A thin left accent ties each card to its column's status. */
  .is-shipped .rm-item { border-inline-start: 2px solid color-mix(in srgb, var(--ery-success) 55%, var(--ery-border)); }
  .is-progress .rm-item { border-inline-start: 2px solid color-mix(in srgb, var(--ery-warning) 55%, var(--ery-border)); }
  .is-planned .rm-item { border-inline-start: 2px solid var(--ery-border-strong); }
  .rm-item-title {
    margin: 0 0 var(--ery-space-1);
    font-size: var(--ery-text-base);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ery-text);
  }
  .rm-item-note {
    margin: 0;
    font-size: var(--ery-text-sm);
    line-height: var(--ery-leading-snug);
    color: var(--ery-text-muted);
  }

  /* ---------- Vote CTA ---------- */
  .rm-vote-wrap {
    padding-block-end: var(--ery-space-24);
  }
  .rm-vote {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ery-space-6);
    padding: var(--ery-space-8);
    background: var(--ery-surface);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-lg);
  }
  .rm-vote-eyebrow {
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ery-brand);
    margin: 0 0 var(--ery-space-2);
  }
  .rm-vote-h {
    margin: 0 0 var(--ery-space-2);
    font-size: var(--ery-text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .rm-vote-b {
    margin: 0;
    font-size: var(--ery-text-sm);
    line-height: var(--ery-leading-relaxed);
    color: var(--ery-text-muted);
    max-inline-size: 38rem;
  }
  .rm-vote-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: var(--ery-touch-min);
    padding-inline: var(--ery-space-5);
    border-radius: var(--ery-radius-sm);
    background: var(--ery-brand);
    color: var(--ery-brand-contrast);
    font-size: var(--ery-text-base);
    font-weight: 500;
    transition: background-color var(--ery-motion-base) var(--ery-ease);
  }
  .rm-vote-cta:hover {
    background: var(--ery-brand-hover);
    color: var(--ery-brand-contrast);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 880px) {
    .rm-cols { grid-template-columns: 1fr; gap: var(--ery-space-4); }
  }
  @media (max-width: 640px) {
    .rm-vote { flex-direction: column; align-items: flex-start; }
    .rm-vote-cta { inline-size: 100%; }
  }
</style>
