---
/*
 * SiteHeader — decision-oriented marketing navigation (ERY-60 → v0.6 locale buildout).
 *
 * Fills the `header` slot of MarketingLayout (the wordmark is already rendered by the layout).
 * IA per the ERY-54 brief: Pricing · Documentation · Blog · Changelog · Roadmap, with the
 * free trial as the single CTA button.
 *
 * Locale-aware: nav labels are translated and the locale-bearing routes (Pricing) carry the
 * current locale prefix. Docs/rollout/blog/changelog are single-language surfaces (docs +
 * editorial collections) and always link to their canonical English paths. A compact language
 * switcher (EN/NL/DE) is rendered at the end of the bar, preserving the current base path.
 */
import CtaButton from "@/components/marketing/CtaButton.astro";
import { localizePath, stripLocalePrefix, localeFromPath, SUPPORTED_LOCALES, type Locale } from "@/lib/locale";

interface Props {
  locale?: Locale;
  /** Marks the current section for aria-current. */
  active?: "pricing" | "rollout" | "docs" | "blog" | "changelog" | null;
}

const { locale = "en", active = null } = Astro.props;

const labels: Record<Locale, Record<string, string>> = {
  en: { pricing: "Pricing", rollout: "Managed rollout", docs: "Documentation", blog: "Blog", changelog: "Release Notes", cta: "Start free trial", menu: "Menu" },
  nl: { pricing: "Prijzen", rollout: "Begeleide uitrol", docs: "Documentatie", blog: "Blog", changelog: "Releasenotes", cta: "Gratis uitproberen", menu: "Menu" },
  de: { pricing: "Preise", rollout: "Begleitete Einführung", docs: "Dokumentation", blog: "Blog", changelog: "Release Notes", cta: "Kostenlos testen", menu: "Menü" },
};
const t = labels[locale];

// Pricing is localized; the rest are single-language canonical paths.
// Managed rollout now lives inline on the landing (#managed-rollout), so it is no
// longer a top-level nav item — it's reachable from the homepage and pricing CTAs.
const links = [
  { key: "docs", label: t.docs, href: "/introduction/" },
  { key: "blog", label: t.blog, href: "/blog/" },
  { key: "changelog", label: t.changelog, href: "/release-notes/" },
] as const;

// Language switcher: keep the visitor on the equivalent path in each locale, but only for the
// pure-marketing surfaces that exist per locale (home + pricing). Elsewhere, switch to that
// locale's home.
const currentLocale = localeFromPath(Astro.url.pathname);
const base = stripLocalePrefix(Astro.url.pathname, currentLocale);
const localizedBase = base === "/" ? base : "/";
const langLinks = SUPPORTED_LOCALES.map((l) => ({
  lang: l,
  href: localizePath(localizedBase, l),
  current: l === locale,
}));
---

<nav aria-label="Primary" class="ery-nav">
  <ul class="ery-nav__list">
    {
      links.map((link) => (
        <li>
          <a href={link.href} class="ery-nav__link" aria-current={active === link.key ? "page" : undefined}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="ery-langswitch ery-nav__desktop" role="group" aria-label="Language">
    {
      langLinks.map((l) => (
        <a
          href={l.href}
          class="ery-langswitch__opt"
          aria-current={l.current ? "true" : undefined}
          hreflang={l.lang}
        >
          {l.lang.toUpperCase()}
        </a>
      ))
    }
  </div>

  <div class="ery-nav__desktop">
    <CtaButton href="https://app.eryxon.eu" ctaId="nav_primary_hosted" surface="site_header" kind="hosted_app" variant="primary" locale={locale} external>
      {t.cta}
    </CtaButton>
  </div>

  <button
    type="button"
    class="ery-nav__toggle"
    aria-expanded="false"
    aria-controls="ery-mobile-menu"
    aria-label={t.menu}
  >
    <span class="ery-nav__bars" aria-hidden="true"></span>
  </button>

  <div id="ery-mobile-menu" class="ery-nav__mobile" hidden>
  <ul class="ery-nav__mobile-list">
    {
      links.map((link) => (
        <li>
          <a href={link.href} class="ery-nav__mobile-link" aria-current={active === link.key ? "page" : undefined}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="ery-nav__mobile-foot">
    <div class="ery-langswitch" role="group" aria-label="Language">
      {
        langLinks.map((l) => (
          <a href={l.href} class="ery-langswitch__opt" aria-current={l.current ? "true" : undefined} hreflang={l.lang}>
            {l.lang.toUpperCase()}
          </a>
        ))
      }
    </div>
    <CtaButton href="https://app.eryxon.eu" ctaId="nav_primary_hosted_mobile" surface="site_header" kind="hosted_app" variant="primary" locale={locale} external>
      {t.cta}
    </CtaButton>
  </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector(".ery-nav__toggle");
  const menu = document.getElementById("ery-mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!open));
      menu.hidden = open;
    });
    // Close when a link is tapped or the viewport grows back to desktop.
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) {
        toggle.setAttribute("aria-expanded", "false");
        menu.hidden = true;
      }
    });
  }
</script>

<style>
  .ery-nav {
    display: flex;
    align-items: center;
    gap: var(--ery-space-5);
  }
  .ery-nav__list {
    display: flex;
    align-items: center;
    gap: var(--ery-space-5);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .ery-nav__link {
    color: var(--ery-text-muted);
    font-size: var(--ery-text-sm);
    font-weight: 500;
  }
  .ery-nav__link:hover,
  .ery-nav__link[aria-current="page"] {
    color: var(--ery-text);
  }

  .ery-langswitch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-sm);
  }
  .ery-langswitch__opt {
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    font-weight: 500;
    color: var(--ery-text-muted);
    padding: 3px 7px;
    border-radius: 4px;
    line-height: 1;
  }
  .ery-langswitch__opt:hover {
    color: var(--ery-text);
    background: var(--ery-surface-subtle);
  }
  .ery-langswitch__opt[aria-current="true"] {
    color: var(--ery-brand-contrast);
    background: var(--ery-brand);
  }

  .ery-nav {
    position: relative;
  }

  /* Hamburger toggle — hidden on desktop, shown on mobile. */
  .ery-nav__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-sm);
    cursor: pointer;
    color: var(--ery-text);
  }
  .ery-nav__bars,
  .ery-nav__bars::before,
  .ery-nav__bars::after {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }
  .ery-nav__bars {
    position: relative;
  }
  .ery-nav__bars::before,
  .ery-nav__bars::after {
    content: "";
    position: absolute;
    left: 0;
  }
  .ery-nav__bars::before { top: -6px; }
  .ery-nav__bars::after { top: 6px; }
  .ery-nav__toggle[aria-expanded="true"] .ery-nav__bars { background: transparent; }
  .ery-nav__toggle[aria-expanded="true"] .ery-nav__bars::before { transform: translateY(6px) rotate(45deg); }
  .ery-nav__toggle[aria-expanded="true"] .ery-nav__bars::after { transform: translateY(-6px) rotate(-45deg); }

  /* Mobile dropdown panel. */
  .ery-nav__mobile {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    min-width: min(280px, calc(100vw - 32px));
    display: flex;
    flex-direction: column;
    gap: var(--ery-space-3);
    padding: var(--ery-space-4);
    background: var(--ery-surface);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-md, 12px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
    z-index: 60;
  }
  .ery-nav__mobile[hidden] { display: none; }
  .ery-nav__mobile-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .ery-nav__mobile-link {
    display: block;
    padding: 10px 12px;
    border-radius: var(--ery-radius-sm);
    color: var(--ery-text);
    font-size: var(--ery-text-sm);
    font-weight: 500;
  }
  .ery-nav__mobile-link:hover,
  .ery-nav__mobile-link[aria-current="page"] {
    background: var(--ery-surface-subtle);
  }
  .ery-nav__mobile-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ery-space-3);
    padding-top: var(--ery-space-3);
    border-top: 1px solid var(--ery-border);
  }

  /* On narrow screens the desktop nav collapses behind the hamburger. */
  @media (max-width: 760px) {
    .ery-nav__list,
    .ery-nav__desktop {
      display: none;
    }
    .ery-nav__toggle {
      display: inline-flex;
    }
  }
</style>
