---
/*
 * Landing.astro — the marketing homepage body.
 *
 * Section flow: hero → product-frame mockup → feature grid → how-it-works (3 steps) → dark API
 * code block → pricing (3 tiers) → managed-rollout contact → dark CTA banner. The `mk-*` classes
 * map to the site `--ery-*` token contract (same approach as `pricing/index.astro`), so the token
 * authority stays in `tokens.css`.
 *
 * Content is locale-driven (`marketing-content.ts`). Per Luke's constraints: NO invented
 * testimonials/stats and NO customer names/logos.
 *
 * All CTAs route through the shared CtaButton primitive so the ERY-33 analytics contract holds.
 */
import CtaButton from "@/components/marketing/CtaButton.astro";
import RolloutInquiry from "@/components/RolloutInquiry.astro";
import { landingCopy, pricingCopy, type PlanFeature } from "@/lib/marketing-content";
import { localizePath, type Locale } from "@/lib/locale";

interface Props {
  locale?: Locale;
}
const { locale = "en" } = Astro.props;
const c = landingCopy(locale);
const p = pricingCopy(locale);

const docsHref = localizePath("/introduction/", locale);
const selfHostHref = localizePath("/guides/self-hosting/", locale);

// Managed rollout now lives inline on this page (#managed-rollout); the hero secondary
// CTA scrolls there instead of routing to the standalone docs page.
const rolloutAnchor = "#managed-rollout";

// Hosted plans + support arrive at v1; until then the "learn more" path is the publisher's site.
const learnMoreHref = "https://www.vanenkhuizen.com/";

const check =
  '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>';
const arrow =
  '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>';
---

<!-- 1 · Hero (kit .mk-hero) ------------------------------------------------- -->
<section class="mk-hero">
  <h1 class="mk-h1">{c.hero.h1}</h1>
  <p class="mk-lead">{c.hero.lead}</p>
  <div class="mk-hero-cta">
    <CtaButton href="https://app.eryxon.eu" ctaId="home_hero_primary_hosted" surface="homepage_hero" kind="hosted_app" variant="primary" locale={locale} external>
      <span>{c.hero.ctaPrimary}</span><Fragment set:html={arrow} />
    </CtaButton>
    <CtaButton href={rolloutAnchor} ctaId="home_hero_secondary_rollout" surface="homepage_hero" kind="rollout_section" variant="secondary" locale={locale}>
      {c.hero.ctaSecondary}
    </CtaButton>
    <CtaButton href={docsHref} ctaId="home_hero_tertiary_docs" surface="homepage_hero" kind="docs" variant="tertiary" locale={locale}>
      {c.hero.ctaTertiary}
    </CtaButton>
  </div>
</section>

<!-- 2 · Product preview frame (kit .mk-product) ----------------------------- -->
<div class="mk-product">
  <div class="mk-product-chrome">
    <span class="mk-product-dot"></span>
    <span class="mk-product-dot"></span>
    <span class="mk-product-dot"></span>
    <div class="mk-product-url">{c.product.url}</div>
  </div>
  <div class="mk-product-shot surface-dark">
    <div class="mk-shot-row">
      <div class="mk-shot-brand">
        <img src="/eryxon-mark-flat.svg" width="20" height="20" alt="" />
        <span>eryxon flow</span>
      </div>
      <div class="mk-shot-cell">{c.product.cell}</div>
      <div class="mk-shot-time">19:46</div>
    </div>
    <div class="mk-shot-title">{c.product.queueTitle}</div>
    <div class="mk-shot-cards">
      {c.product.cards.map((card) => (
        <div class="mk-shot-card">
          <div class:list={["mk-shot-stripe", `is-${card.stripe}`]}></div>
          <div class="mk-shot-card-body">
            <div class="mk-shot-card-row">
              <span class="mk-shot-wo">{card.wo}</span>
              <span class:list={["mk-shot-tag", `is-${card.tagCls}`]}>{card.tag}</span>
            </div>
            <div class="mk-shot-card-title">{card.op}</div>
            <div class="mk-shot-card-meta">{card.meta}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- 3 · Feature grid 00–05 (kit .mk-feature-grid) --------------------------- -->
<section class="mk-section" id="product">
  <div class="mk-section-head">
    <span class="mk-section-eyebrow">{c.features.eyebrow}</span>
    <h2 class="mk-h2">{c.features.h2}</h2>
    <p class="mk-section-lead">{c.features.lead}</p>
  </div>
  <div class="mk-feature-grid">
    {c.features.items.map((f, i) => (
      <article class="mk-feature">
        <div class="mk-feature-num">{String(i).padStart(2, "0")}</div>
        <h3 class="mk-feature-title">{f.title}</h3>
        <p class="mk-feature-body">{f.body}</p>
      </article>
    ))}
  </div>
</section>

<!-- 4 · How it works (kit .mk-steps) ---------------------------------------- -->
<section class="mk-section" id="how">
  <div class="mk-section-head">
    <span class="mk-section-eyebrow">{c.how.eyebrow}</span>
    <h2 class="mk-h2">{c.how.h2}</h2>
  </div>
  <ol class="mk-steps">
    {c.how.steps.map((s) => (
      <li class="mk-step">
        <span class="mk-step-num">{s.n}</span>
        <div>
          <h3 class="mk-step-h">{s.h}</h3>
          <p class="mk-step-b">{s.b}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<!-- 5 · API code block, dark band (kit .mk-section-dark .mk-api-grid) -------- -->
<section class="mk-section-dark surface-dark" id="api">
  <div class="mk-api-grid">
    <div>
      <span class="mk-section-eyebrow on-dark">{c.api.eyebrow}</span>
      <h2 class="mk-h2 on-dark">{c.api.h2}</h2>
      <p class="mk-section-lead on-dark">{c.api.lead}</p>
      <ul class="mk-api-list">
        {c.api.bullets.map((b) => (
          <li><Fragment set:html={check} /><span>{b}</span></li>
        ))}
      </ul>
    </div>
    <div class="mk-code">
      <div class="mk-code-head">
        <span class="mk-code-lang">cURL</span>
      </div>
      <pre>{`$ curl https://app.eryxon.eu/api/jobs \\
    -H "Authorization: Bearer ery_live_..." \\
    -X POST -H "Content-Type: application/json" \\
    -d '{
      "job_number": "WO-4218",
      "due_date":   "2026-06-12",
      "parts": [
        { "part_number": "PN-902-A",
          "quantity":   200,
          "operations": ["cut","bend","weld"] }
      ]
    }'

> 201 Created
> { "id": "job_01H...", "job_number": "WO-4218" }`}</pre>
    </div>
  </div>
</section>

<!-- 6 · Pricing, inline (kit .mk-pricing-grid / .mk-tier, three tiers) ------- -->
<section class="mk-section" id="pricing">
  <div class="mk-section-head">
    <span class="mk-section-eyebrow">{c.pricing.eyebrow}</span>
    <h2 class="mk-h2">{c.pricing.h2}</h2>
    <p class="mk-section-lead">{c.pricing.lead}</p>
  </div>
  <div class="mk-pricing-grid">
    <!-- Tier 1 — Hosted demo (free, 30 days, usage limits) — the recommended starting point -->
    <div class="mk-tier is-featured">
      <div class="mk-tier-name">{p.plans.trial.name}</div>
      <div class="mk-tier-price">{p.plans.trial.price}<span>{p.plans.trial.period}</span></div>
      <div class="mk-tier-sub">{p.plans.trial.sub}</div>
      <ul class="mk-tier-features">
        {p.plans.trial.features.map((f: PlanFeature) => (
          <li class:list={[f.muted && "muted"]}><Fragment set:html={check} /><span>{f.text}</span></li>
        ))}
      </ul>
      <CtaButton href="https://app.eryxon.eu" ctaId="home_pricing_trial_signup" surface="homepage_pricing" kind="hosted_app" variant="secondary" locale={locale} external>
        {p.plans.trial.cta}
      </CtaButton>
    </div>

    <!-- Tier 2 — Hosted & support (paid; arrives at v1, "learn more" links to the publisher's site) -->
    <div class="mk-tier">
      <span class="mk-tier-flag">{p.plans.managed.flag}</span>
      <div class="mk-tier-name">{p.plans.managed.name}</div>
      <div class="mk-tier-price">{p.plans.managed.price}</div>
      <div class="mk-tier-sub">{p.plans.managed.sub}</div>
      <ul class="mk-tier-features">
        {p.plans.managed.features.map((f: PlanFeature) => (
          <li class:list={[f.muted && "muted"]}><Fragment set:html={check} /><span>{f.text}</span></li>
        ))}
      </ul>
      <a class="mk-tier-link" href={learnMoreHref} target="_blank" rel="noopener noreferrer" data-cta-id="home_pricing_hosted_learnmore" data-cta-surface="homepage_pricing" data-cta-kind="external_site">
        {p.plans.managed.cta}
      </a>
    </div>

    <!-- Tier 3 — Self-hosted (Apache 2.0, unlimited, DIY) -->
    <div class="mk-tier">
      <div class="mk-tier-name">{p.plans.selfHosted.name}</div>
      <div class="mk-tier-price">{p.plans.selfHosted.price}<span>{p.plans.selfHosted.period}</span></div>
      <div class="mk-tier-sub">{p.plans.selfHosted.sub}</div>
      <ul class="mk-tier-features">
        {p.plans.selfHosted.features.map((f: PlanFeature) => (
          <li class:list={[f.muted && "muted"]}><Fragment set:html={check} /><span>{f.text}</span></li>
        ))}
      </ul>
      <CtaButton href={selfHostHref} ctaId="home_pricing_selfhost_guide" surface="homepage_pricing" kind="docs" variant="secondary" locale={locale}>
        {p.plans.selfHosted.ctaGuide}
      </CtaButton>
      <a class="mk-tier-link" href={`${rolloutAnchor}`} data-cta-id="home_pricing_selfhost_consulting" data-cta-surface="homepage_pricing" data-cta-kind="rollout_section">
        {p.plans.selfHosted.ctaConsulting}
      </a>
    </div>
  </div>
</section>

<!-- 6b · Managed rollout, inline (folded in from the standalone page) -------- -->
<section class="mk-section mk-rollout" id="managed-rollout">
  <div class="mk-rollout-intro">
    <span class="mk-section-eyebrow">{c.rollout.eyebrow}</span>
    <h2 class="mk-h2">{c.rollout.h2}</h2>
    <p class="mk-section-lead">{c.rollout.lead}</p>
    <RolloutInquiry label={c.rollout.cta} locale={locale} />
  </div>
</section>

<!-- 7 · CTA banner, dark band (kit .mk-cta-banner) -------------------------- -->
<section class="mk-cta-banner surface-dark">
  <div class="mk-cta-wrap">
    <div>
      <h2 class="mk-h2 on-dark">{c.cta.h2}</h2>
      <p class="mk-section-lead on-dark mk-cta-lead">{c.cta.lead}</p>
    </div>
    <div class="mk-cta-actions">
      <CtaButton href="https://app.eryxon.eu" ctaId="home_cta_primary_hosted" surface="homepage_cta" kind="hosted_app" variant="primary" locale={locale} external>
        <span>{c.cta.ctaPrimary}</span><Fragment set:html={arrow} />
      </CtaButton>
      <a class="mk-btn-on-dark" href={selfHostHref} data-cta-id="home_cta_secondary_selfhost" data-cta-surface="homepage_cta" data-cta-kind="docs">
        {c.cta.ctaSecondary}
      </a>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     Kit marketing landing — ported from ui_kits/marketing/styles.css.
     Raw kit classes preserved; kit HSL tokens mapped to the --ery-* contract.
     ============================================================ */

  /* ---------- Hero ---------- */
  .mk-hero {
    text-align: center;
    max-inline-size: 900px;
    margin-inline: auto;
    padding: var(--ery-pad-hero) var(--ery-pad-section) var(--ery-space-12);
  }
  .mk-h1 {
    font-size: clamp(var(--ery-text-4xl), 5.5vw, var(--ery-text-6xl));
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 auto var(--ery-space-5);
    text-wrap: balance;
  }
  .mk-lead {
    max-inline-size: 640px;
    margin: 0 auto;
    font-size: var(--ery-text-lg);
    line-height: 1.55;
    color: var(--ery-text-muted);
  }
  .mk-hero-cta {
    margin-block-start: var(--ery-space-8);
    display: flex;
    gap: var(--ery-space-3);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ---------- Product preview frame ---------- */
  .mk-product {
    max-inline-size: 1080px;
    margin: var(--ery-space-6) auto var(--ery-space-24);
    border-radius: var(--ery-radius-lg);
    border: 1px solid var(--ery-border);
    background: var(--ery-surface);
    box-shadow: var(--ery-shadow);
    overflow: hidden;
  }
  .mk-product-chrome {
    display: flex;
    align-items: center;
    gap: var(--ery-space-2);
    padding: var(--ery-space-3) var(--ery-space-4);
    background: var(--ery-surface-subtle);
    border-block-end: 1px solid var(--ery-border);
  }
  .mk-product-dot {
    inline-size: 10px;
    block-size: 10px;
    border-radius: 50%;
    background: var(--ery-border-strong);
  }
  .mk-product-dot:nth-child(1) { background: var(--ery-error); }
  .mk-product-dot:nth-child(2) { background: var(--ery-warning); }
  .mk-product-dot:nth-child(3) { background: var(--ery-success); }
  .mk-product-url {
    margin-inline-start: var(--ery-space-3);
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    color: var(--ery-text-muted);
  }
  .mk-product-shot {
    padding: var(--ery-space-6);
  }
  .mk-shot-row {
    display: flex;
    align-items: center;
    gap: var(--ery-space-4);
  }
  .mk-shot-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--ery-space-2);
    font-weight: 600;
    font-size: var(--ery-text-sm);
    color: var(--ery-text-on-dark);
  }
  .mk-shot-cell {
    padding: var(--ery-space-1) var(--ery-space-3);
    border-radius: var(--ery-radius-pill);
    background: color-mix(in srgb, var(--ery-brand-on-dark) 12%, transparent);
    color: var(--ery-brand-on-dark);
    font-size: var(--ery-text-sm);
    font-weight: 500;
  }
  .mk-shot-time {
    margin-inline-start: auto;
    font-family: var(--ery-font-mono);
    color: var(--ery-text-on-dark-muted);
    font-size: var(--ery-text-sm);
  }
  .mk-shot-title {
    font-size: var(--ery-text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: var(--ery-space-6) 0 var(--ery-space-3);
    color: var(--ery-text-on-dark);
  }
  .mk-shot-cards {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--ery-space-3);
  }
  .mk-shot-card {
    display: flex;
    border-radius: var(--ery-radius-sm);
    border: 1px solid var(--ery-border-dark);
    background: var(--ery-surface-dark);
    overflow: hidden;
  }
  .mk-shot-stripe { inline-size: 4px; }
  .mk-shot-stripe.is-active { background: var(--ery-warning); }
  .mk-shot-stripe.is-pending { background: var(--ery-border-dark); }
  .mk-shot-stripe.is-on-hold { background: var(--ery-error); }
  .mk-shot-card-body { padding: var(--ery-space-2) var(--ery-space-3); flex: 1; min-inline-size: 0; }
  .mk-shot-card-row { display: flex; justify-content: space-between; align-items: center; gap: var(--ery-space-2); }
  .mk-shot-wo { font-family: var(--ery-font-mono); font-size: 11px; color: var(--ery-text-on-dark-muted); }
  .mk-shot-tag {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 2px 5px;
    border-radius: 3px;
  }
  .mk-shot-tag.is-today { background: color-mix(in srgb, var(--ery-warning) 15%, transparent); color: var(--ery-warning); }
  .mk-shot-tag.is-soon { background: color-mix(in srgb, var(--ery-warning) 15%, transparent); color: var(--ery-warning); }
  .mk-shot-tag.is-overdue { background: color-mix(in srgb, var(--ery-error) 15%, transparent); color: var(--ery-error); }
  .mk-shot-card-title { font-size: var(--ery-text-sm); font-weight: 600; margin-block-start: var(--ery-space-1); color: var(--ery-text-on-dark); }
  .mk-shot-card-meta { font-size: 11px; color: var(--ery-text-on-dark-muted); margin-block-start: var(--ery-space-1); }

  /* ---------- Sections ---------- */
  .mk-section {
    padding: var(--ery-space-24) var(--ery-pad-section);
    max-inline-size: 1180px;
    margin-inline: auto;
  }
  .mk-section-dark {
    padding: var(--ery-space-24) 0;
  }
  .mk-section-head {
    text-align: center;
    max-inline-size: 720px;
    margin: 0 auto var(--ery-space-16);
  }
  .mk-section-eyebrow {
    display: inline-block;
    margin-block-end: var(--ery-space-3);
    font-size: var(--ery-text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ery-brand);
  }
  .mk-section-eyebrow.on-dark { color: var(--ery-brand-on-dark); }
  .mk-h2 {
    font-size: clamp(var(--ery-text-2xl), 3.5vw, var(--ery-text-4xl));
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-wrap: balance;
    margin: 0;
  }
  .mk-h2.on-dark { color: var(--ery-text-on-dark); }
  .mk-section-lead {
    margin-block-start: var(--ery-space-4);
    font-size: var(--ery-text-lg);
    color: var(--ery-text-muted);
    line-height: 1.55;
  }
  .mk-section-lead.on-dark { color: var(--ery-text-on-dark-muted); }

  /* ---------- Feature grid ---------- */
  .mk-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-block-start: 1px solid var(--ery-border);
    border-inline-start: 1px solid var(--ery-border);
  }
  .mk-feature {
    padding: var(--ery-space-8);
    border-inline-end: 1px solid var(--ery-border);
    border-block-end: 1px solid var(--ery-border);
  }
  .mk-feature-num {
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    font-weight: 600;
    color: var(--ery-brand);
    margin-block-end: var(--ery-space-4);
  }
  .mk-feature-title {
    font-size: var(--ery-text-lg);
    font-weight: 600;
    margin: 0 0 var(--ery-space-3);
    letter-spacing: -0.01em;
  }
  .mk-feature-body {
    font-size: var(--ery-text-sm);
    color: var(--ery-text-muted);
    line-height: 1.55;
    margin: 0;
  }

  /* ---------- How it works ---------- */
  .mk-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--ery-space-6);
  }
  .mk-step {
    background: var(--ery-surface);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-lg);
    padding: var(--ery-space-8);
  }
  .mk-step-num {
    display: inline-block;
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-sm);
    font-weight: 600;
    color: var(--ery-brand);
    letter-spacing: 0.08em;
    margin-block-end: var(--ery-space-4);
  }
  .mk-step-h { font-size: var(--ery-text-lg); font-weight: 600; margin: 0 0 var(--ery-space-3); letter-spacing: -0.01em; }
  .mk-step-b { font-size: var(--ery-text-sm); line-height: 1.55; color: var(--ery-text-muted); margin: 0; }

  /* ---------- API block ---------- */
  .mk-api-grid {
    max-inline-size: 1180px;
    margin-inline: auto;
    padding: 0 var(--ery-pad-section);
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--ery-space-16);
    align-items: center;
  }
  .mk-api-list {
    list-style: none;
    padding: 0;
    margin: var(--ery-space-8) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--ery-space-3);
  }
  .mk-api-list li {
    display: flex;
    gap: var(--ery-space-3);
    align-items: center;
    font-size: var(--ery-text-base);
    color: var(--ery-text-on-dark);
  }
  .mk-api-list :global(svg) { color: var(--ery-brand-on-dark); flex-shrink: 0; }
  .mk-code {
    background: var(--ery-code-bg);
    border: 1px solid var(--ery-code-border);
    border-radius: var(--ery-radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }
  .mk-code-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--ery-space-2) var(--ery-space-4);
    background: var(--ery-surface-dark);
    border-block-end: 1px solid var(--ery-code-border);
  }
  .mk-code-lang {
    font-family: var(--ery-font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--ery-brand-on-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .mk-code pre {
    margin: 0;
    padding: var(--ery-space-5);
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-sm);
    line-height: 1.65;
    color: var(--ery-code-text);
    white-space: pre;
    overflow: auto;
  }

  /* ---------- CTA banner ---------- */
  .mk-cta-banner {
    padding: var(--ery-space-20) var(--ery-pad-section);
  }
  .mk-cta-wrap {
    max-inline-size: 1180px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: var(--ery-space-12);
    align-items: center;
  }
  .mk-cta-lead { margin-block-start: var(--ery-space-3); }
  .mk-cta-actions { display: flex; gap: var(--ery-space-3); flex-wrap: wrap; align-items: center; }
