---
/*
 * Wordmark — the real Eryxon brand lockup (ERY-60 fidelity pass).
 *
 * Ports the canonical kit mark (`assets/eryxon-mark-light.svg`): a flat blue
 * rounded square with three offset bars. Inlined as SVG so it inherits the
 * design-token brand color and scales crisply in the 64px header.
 *
 * The kit rule: the mark/wordmark uses lowercase "eryxon"; the product name
 * "Eryxon Flow" keeps its capitals in body copy. Here the lockup reads
 * "Eryxon Flow" because the header is the product surface, not the company
 * wordmark — the mark carries the lowercase brand, the text names the product.
 */
interface Props {
  /** Render as a plain span (no link) when the parent already wraps a link. */
  href?: string | null;
}
const { href = "/" } = Astro.props;
const Tag = href ? "a" : "span";
const attrs = href ? { href } : {};
---

<Tag class="ery-wordmark" {...attrs} aria-label="Eryxon Flow — home">
  <svg
    class="ery-wordmark__mark"
    width="28"
    height="28"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
  >
    <rect width="32" height="32" rx="7" fill="var(--ery-brand)"></rect>
    <rect x="2.5" y="2.5" width="27" height="27" rx="5" fill="var(--ery-surface)"></rect>
    <rect x="7" y="7.5" width="18" height="3" rx="1.5" fill="var(--ery-brand)"></rect>
    <rect x="7" y="14.5" width="13" height="3" rx="1.5" fill="var(--ery-brand)" opacity="0.5"></rect>
    <rect x="7" y="21.5" width="18" height="3" rx="1.5" fill="var(--ery-brand)"></rect>
  </svg>
  <span class="ery-wordmark__text">Eryxon<span class="ery-wordmark__sub">Flow</span></span>
</Tag>

<style>
  .ery-wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--ery-space-2);
    color: var(--ery-text);
    font-weight: 600;
    letter-spacing: var(--ery-tracking-tight);
    line-height: 1;
  }
  .ery-wordmark:hover {
    color: var(--ery-text);
    text-decoration: none;
  }
  .ery-wordmark__mark {
    display: block;
    flex-shrink: 0;
    border-radius: var(--ery-radius-sm);
  }
  .ery-wordmark__text {
    font-size: var(--ery-text-lg);
  }
  .ery-wordmark__sub {
    color: var(--ery-text-muted);
    font-weight: 500;
    margin-inline-start: 0.35ch;
  }
  .ery-wordmark:hover .ery-wordmark__sub {
    color: var(--ery-brand);
  }
</style>
