---
/*
 * Pricing — `/pricing/`.
 *
 * Ported from the marketing design-system kit's services/plans template
 * (`docs/Eryxon Design System/ui_kits/marketing/services.html`, the `.svc-plans`
 * 3-tier grid + `.svc-hero`, lines 16-32 / 34-85 / 290-354). The kit grid is
 * explicitly templated as "self-host / hosted trial / managed", which maps 1:1 to
 * the three tiers here: Free to start (trial) / Hosted (featured) / Managed services.
 *
 * Kit fidelity: classes/markup follow the kit's `svc-plan` structure (head + dot,
 * name, price+period span, sub, divider, feature list with check svg + `.muted`
 * lines, block CTA). The kit's `mk-*`/`svc-*` raw classes are translated to the
 * site's `--ery-*` token contract (ERY-56), the same way `index.astro` maps the kit.
 *
 * CTAs route through the site primitives: hosted-app CtaButton (free trial) and
 * RolloutInquiry mailto (managed services). The Hosted tier is "coming soon" with no
 * price and a non-actionable CTA, per Luke's content.
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import CtaButton from "@/components/marketing/CtaButton.astro";
import RolloutInquiry from "@/components/RolloutInquiry.astro";

const title = "Pricing — Eryxon Flow";
const description =
  "Start free for 30 days, run a managed rollout, or use the hosted version when it lands. One plan per deployment style.";

// Reusable check glyph (kit `svc-plan-features svg`).
const check =
  '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>';
---

<SiteLayout title={title} description={description} activeNav="pricing">
  <!-- Hero — kit `.svc-hero` -->
  <section class="ery-container svc-hero">
    <p class="eyebrow">Pricing</p>
    <h1>One plan per deployment style.</h1>
    <p class="lede">
      Try it free for 30 days. Run it self-hosted today, or let us put it into production for you.
    </p>
  </section>

  <!-- Plan grid — kit `.svc-plans` 3 tiers -->
  <section class="ery-container svc-plans" aria-label="Plans">
    <!-- Tier 1 — Free to start (kit Plan A) -->
    <article class="svc-plan">
      <div class="svc-plan-head">
        <span class="svc-plan-dot svc-plan-dot--neutral"></span>
        <span>Free to start</span>
      </div>
      <h2 class="svc-plan-name">Free to start</h2>
      <div class="svc-plan-price">Free<span>· 30-day trial</span></div>
      <p class="svc-plan-sub">Run the full product for 30 days. No card.</p>
      <hr class="svc-plan-divider" />
      <ul class="svc-plan-features">
        <li><Fragment set:html={check} /><span>Full feature access for 30 days</span></li>
        <li><Fragment set:html={check} /><span>Operator terminals on your tablets</span></li>
        <li><Fragment set:html={check} /><span>REST API and webhooks</span></li>
        <li><Fragment set:html={check} /><span>No card up front</span></li>
      </ul>
      <CtaButton
        href="https://app.eryxon.eu"
        ctaId="pricing_free_trial"
        surface="pricing_plans"
        kind="hosted_app"
        variant="secondary"
        external
      >
        Start free
      </CtaButton>
    </article>

    <!-- Tier 2 — Hosted, coming soon (kit Plan B, featured) -->
    <article class="svc-plan is-featured is-soon">
      <span class="svc-plan-flag">Coming soon</span>
      <div class="svc-plan-head">
        <span class="svc-plan-dot"></span>
        <span>Hosted</span>
      </div>
      <h2 class="svc-plan-name">Hosted</h2>
      <div class="svc-plan-price">Coming soon</div>
      <p class="svc-plan-sub">Fully managed at app.eryxon.eu. Pricing lands soon.</p>
      <hr class="svc-plan-divider" />
      <ul class="svc-plan-features">
        <li><Fragment set:html={check} /><span>Hosted and run for you</span></li>
        <li><Fragment set:html={check} /><span>Daily backups</span></li>
        <li><Fragment set:html={check} /><span>Updates handled automatically</span></li>
        <li class="muted"><Fragment set:html={check} /><span>Pricing to be announced</span></li>
      </ul>
      <span class="svc-plan-cta-soon" aria-disabled="true">Coming soon</span>
    </article>

    <!-- Tier 3 — Managed services (kit Plan C) -->
    <article class="svc-plan">
      <div class="svc-plan-head">
        <span class="svc-plan-dot svc-plan-dot--warning"></span>
        <span>Managed services</span>
      </div>
      <h2 class="svc-plan-name">Managed services</h2>
      <div class="svc-plan-price">Let's talk</div>
      <p class="svc-plan-sub">We deploy it, connect your ERP, and roll it out across the floor.</p>
      <hr class="svc-plan-divider" />
      <ul class="svc-plan-features">
        <li><Fragment set:html={check} /><span>Deployment on your infrastructure</span></li>
        <li><Fragment set:html={check} /><span>ERP integration over REST and webhooks</span></li>
        <li><Fragment set:html={check} /><span>Rollout sequenced cell by cell</span></li>
        <li><Fragment set:html={check} /><span>Scoped to your shop</span></li>
      </ul>
      <RolloutInquiry label="Get in touch" locale="en" />
    </article>
  </section>
</SiteLayout>

<style>
  /* Hero — ported from kit `.svc-hero` (services.html 16-32). */
  .svc-hero {
    text-align: center;
    max-inline-size: 52rem;
    padding-block: var(--ery-pad-hero) var(--ery-space-8);
  }
  .eyebrow {
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-sm);
    color: var(--ery-text-muted);
    margin: 0 0 var(--ery-space-3);
  }
  .svc-hero h1 {
    /* Kit `.svc-hero h1`: clamp(32px, 4.5vw, 48px). */
    font-size: clamp(var(--ery-text-3xl), 4.5vw, var(--ery-text-5xl));
    line-height: var(--ery-leading-tight);
    text-wrap: balance;
    margin: 0 0 var(--ery-space-4);
  }
  .lede {
    font-size: var(--ery-text-lg);
    color: var(--ery-text-muted);
    max-inline-size: 40rem;
    margin-inline: auto;
  }

  /* Plan grid — ported from kit `.svc-plans` (services.html 34-85). */
  .svc-plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--ery-space-4);
    padding-block-end: var(--ery-space-16);
    align-items: stretch;
  }
  @media (max-width: 860px) {
    .svc-plans {
      grid-template-columns: 1fr;
      max-inline-size: 32rem;
      margin-inline: auto;
    }
  }

  .svc-plan {
    display: flex;
    flex-direction: column;
    gap: var(--ery-space-4);
    padding: var(--ery-space-6);
    background-color: var(--ery-surface);
    border: 1px solid var(--ery-border);
    border-radius: var(--ery-radius-lg);
    position: relative;
  }
  .svc-plan.is-featured {
    border-color: color-mix(in srgb, var(--ery-brand) 40%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--ery-brand) 20%, transparent),
      var(--ery-shadow);
  }
  .svc-plan-flag {
    position: absolute;
    top: calc(-1 * var(--ery-space-3));
    left: var(--ery-space-6);
    background-color: var(--ery-brand);
    color: var(--ery-brand-contrast);
    padding: var(--ery-space-1) var(--ery-space-3);
    border-radius: var(--ery-radius-pill);
    font-size: var(--ery-text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .svc-plan-head {
    display: flex;
    align-items: center;
    gap: var(--ery-space-2);
    font-family: var(--ery-font-mono);
    font-size: var(--ery-text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ery-text-muted);
  }
  .svc-plan-dot {
    inline-size: 8px;
    block-size: 8px;
    border-radius: 50%;
    background-color: var(--ery-brand);
  }
  .svc-plan-dot--neutral {
    background-color: var(--ery-text-subtle);
  }
  .svc-plan-dot--warning {
    background-color: var(--ery-warning);
  }

  .svc-plan-name {
    margin: 0;
    font-size: var(--ery-text-xl);
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .svc-plan-price {
    font-size: var(--ery-text-4xl);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-feature-settings: "tnum";
  }
  .svc-plan-price span {
    margin-left: var(--ery-space-2);
    font-size: var(--ery-text-sm);
    font-weight: 500;
    color: var(--ery-text-muted);
  }
  .svc-plan-sub {
    margin: 0;
    font-size: var(--ery-text-sm);
    color: var(--ery-text-muted);
  }
  .svc-plan-divider {
    border: 0;
    block-size: 1px;
    background-color: var(--ery-border);
    margin: 0;
  }

  .svc-plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ery-space-3);
    flex: 1;
  }
  .svc-plan-features li {
    display: flex;
    gap: var(--ery-space-2);
    align-items: flex-start;
    font-size: var(--ery-text-sm);
    line-height: var(--ery-leading-normal);
  }
  .svc-plan-features :global(svg) {
    color: var(--ery-success);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .svc-plan-features li.muted,
  .svc-plan-features li.muted :global(svg) {
    color: var(--ery-text-subtle);
  }

  /* Disabled "coming soon" CTA — visually consistent with secondary CtaButton,
     but non-actionable (no link, no analytics). */
  .svc-plan-cta-soon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: var(--ery-touch-min);
    padding-inline: var(--ery-space-5);
    border-radius: var(--ery-radius-sm);
    border: 1px dashed var(--ery-border-strong);
    font-size: var(--ery-text-base);
    font-weight: 500;
    color: var(--ery-text-subtle);
    cursor: default;
  }

  /* The site primitives (CtaButton / RolloutInquiry) render their own buttons;
     stretch them full-width to match the kit's `mk-btn-block`. */
  .svc-plan :global(.ery-cta),
  .svc-plan :global(.rollout-email-intent),
  .svc-plan .svc-plan-cta-soon {
    inline-size: 100%;
  }
</style>
