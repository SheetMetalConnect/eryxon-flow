---
/*
 * Pricing — `/pricing/` (root locale = en).
 *
 * Thin shell over the shared `Pricing.astro` component, which ports the kit services/plans
 * template (`ui_kits/marketing/services.html`). Localized variants render the same component at
 * `/nl/pricing/` and `/de/pricing/` (`pages/[locale]/pricing.astro`). Luke's three-tier model:
 * Free to start (30-day trial) / Hosted (coming soon) / Managed services (get in touch).
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import Pricing from "@/components/marketing/Pricing.astro";
import { pricingCopy } from "@/lib/marketing-content";

const c = pricingCopy("en");
---

<SiteLayout title={c.title} description={c.description} locale="en" activeNav="pricing">
  <Pricing locale="en" />
</SiteLayout>
