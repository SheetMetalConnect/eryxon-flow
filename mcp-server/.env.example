# =============================================================================
# Eryxon Flow MCP Server Configuration
# =============================================================================

# v0.5.0 final release supports direct Supabase access for self-hosted
# deployments. Use a service role key and keep this server on trusted
# infrastructure.

# -----------------------------------------------------------------------------
# Direct Mode (Self-Hosted)
# -----------------------------------------------------------------------------
# Requires service role key for direct Supabase access.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# -----------------------------------------------------------------------------
# Optional Features
# -----------------------------------------------------------------------------

# Redis for caching
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Deployment Configuration
# -----------------------------------------------------------------------------

# HTTP server settings, used when MCP_TRANSPORT=http
MCP_TRANSPORT=http
MCP_PORT=3001
MCP_HOST=0.0.0.0
MCP_BIND_PUBLIC=true

# Required when MCP_BIND_PUBLIC=true. Use a long random value and send it as:
# Authorization: Bearer <token>
MCP_BEARER=change-this-long-random-token

# Comma-separated hostnames allowed by DNS rebinding protection.
# Add your MCP domain when exposing the HTTP transport behind a reverse proxy.
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
