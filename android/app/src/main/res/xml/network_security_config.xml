<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Default policy: HTTPS only, system + user CAs honoured.
      Operators on Eryxon Cloud always go through TLS to Supabase / app.eryxon.eu.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!--
      Self-hosted MES installs commonly run on plant-internal hostnames over
      cleartext until the customer fronts them with a reverse proxy. Allow
      common LAN ranges and *.local without forcing the customer to ship
      a custom build. Any production install should still be put behind TLS.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">.local</domain>
        <domain includeSubdomains="true">.lan</domain>
    </domain-config>
</network-security-config>
